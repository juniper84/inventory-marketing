# Base URL of the backend API (where the contact form posts leads).
# Include the /api/v1 global prefix — the backend serves everything under it.
# Local dev: http://localhost:3000/api/v1
# Production: https://api.newvisioninventory.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Plausible analytics — set to your domain to enable tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
